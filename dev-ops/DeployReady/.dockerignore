# Version control
.git
.gitignore

# Environment & secrets
.env
*.pem
*.key

# Documentation & screenshots (not needed in image)
*.md
screenshots/
LICENSE

# Docker files (avoid recursive builds)
docker-compose.yml
Dockerfile

# OS junk
.DS_Store

# Terraform (if present)
.terraform/
*.tfstate
*.tfvars

# Root-level stale files
package-lock.json
